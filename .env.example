# Server
PORT=3000

# Logging: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Google Sheets (required for recording jobs to a sheet)
# Path to your service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account-key.json

# Optional: default Google Sheet URL (can also be set per request in the UI)
JOB_AGENT_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit

# Optional: folder where tailored resume PDFs are saved (default: data/resumes)
# RESUME_OUTPUT_DIR=data/resumes

JSEARCH_HOST=jsearch.p.rapidapi.com

# Job search (optional; without this, mock jobs are used)
# Get your key from https://rapidapi.com/ (subscribe to JSearch API)
RAPIDAPI_KEY=
